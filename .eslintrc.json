{
  "env": {
    "browser": true,
    "es2020": true,
    "webextensions": true,
    "jest": true
  },
  "extends": ["eslint:recommended", "prettier"],
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "script"
  },
  "globals": {
    "i18nInit": "writable",
    "i18nSetLang": "writable",
    "i18nGetLang": "writable",
    "t": "writable",
    "translatePage": "writable",
    "I18N_DICTIONARIES_PROMISE": "writable",
    "I18N_BG_READY": "writable",
    "initLangSwitcher": "writable",
    "updateLangButtons": "writable",
    "i18nCurrentLang": "writable",
    "i18nDictionary": "writable",
    "i18nDictionaries": "writable",
    "I18N_STORAGE_KEY": "writable",
    "I18N_DEFAULT_LANG": "writable",
    "I18N_SUPPORTED_LANGS": "writable",
    "AUTO_COLORS": "readonly",
    "HEX_COLOR_PATTERN": "readonly"
  },
  "rules": {
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
    "no-console": ["warn", { "allow": ["warn", "error"] }],
    "eqeqeq": "error",
    "no-var": "error",
    "prefer-const": "error"
  },
  "overrides": [
    {
      "files": ["shared/i18n.js", "shared/dictionaries.js", "background/i18n-init.js"],
      "rules": {
        "no-unused-vars": "off",
        "no-redeclare": "off"
      }
    },
    {
      "files": ["shared/constants.js"],
      "rules": {
        "no-unused-vars": "off",
        "no-redeclare": "off"
      }
    },
    {
      "files": ["background/validation.js"],
      "globals": {
        "MAX_SESSIONS": "readonly"
      },
      "rules": {
        "no-redeclare": "off"
      }
    },
    {
      "files": ["background/export-import.js", "background/session-crud.js"],
      "globals": {
        "MAX_SESSIONS": "readonly"
      }
    },
    {
      "files": ["popup/popup.js"],
      "globals": {
        "initLangSwitcher": "off",
        "updateLangButtons": "off",
        "openMenuId": "writable",
        "toggleContextMenu": "readonly",
        "handleMenuAction": "readonly",
        "closeContextMenu": "readonly",
        "initSearch": "readonly",
        "filterSessionList": "readonly",
        "handleExport": "readonly",
        "handleImport": "readonly",
        "loadStorageStats": "readonly",
        "initSaveTagEvents": "readonly",
        "getSaveTags": "readonly",
        "resetSaveTags": "readonly",
        "initTagEditorEvents": "readonly",
        "openTagEditor": "readonly",
        "startInlineRename": "readonly"
      }
    },
    {
      "files": ["popup/context-menu.js"],
      "globals": {
        "refreshAll": "readonly",
        "startInlineRename": "readonly",
        "openTagEditor": "readonly",
        "cachedSessions": "writable",
        "showUndoToast": "readonly",
        "downloadJson": "readonly"
      },
      "rules": {
        "no-unused-vars": [
          "error",
          {
            "varsIgnorePattern": "^(toggleContextMenu|handleMenuAction)$",
            "argsIgnorePattern": "^_"
          }
        ],
        "require-atomic-updates": "off"
      }
    },
    {
      "files": ["popup/inline-rename.js"],
      "globals": {
        "loadSessions": "readonly"
      },
      "rules": {
        "no-unused-vars": [
          "error",
          { "varsIgnorePattern": "^startInlineRename$", "argsIgnorePattern": "^_" }
        ]
      }
    },
    {
      "files": ["popup/ui-utils.js"],
      "globals": {
        "HEX_COLOR_PATTERN": "readonly"
      }
    }
  ]
}
